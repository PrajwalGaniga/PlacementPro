# PlacementPro Environment Configuration
# Copy this file to .env and fill in your values

# ── Database ─────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=placementpro

# ── Security ─────────────────────────────────────────────────
JWT_SECRET=SIT_HACKATHON_2024_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ── AI ───────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Email (Gmail SMTP) ───────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ── Dev Mode (true = restrict emails to allow-list) ──────────
DEV_MODE=true
DEV_ALLOWED_EMAILS=["ishwarya9448@gmail.com","anvithashetty41@gmail.com","prajwalganiga06@gmail.com"]

# ── Server ────────────────────────────────────────────────────
PORT=8000
